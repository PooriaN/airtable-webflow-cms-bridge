# Required provider credentials
AIRTABLE_API_KEY=your_airtable_personal_access_token
WEBFLOW_API_TOKEN=your_webflow_api_token

# Required app secrets in production-like deployments
APP_PASSWORD=choose_a_shared_dashboard_password
APP_SESSION_SECRET=replace_with_a_long_random_string

# Optional token for Airtable automation-triggered syncs
APP_AUTOMATION_TOKEN=

# Database connection: set DATABASE_URL or POSTGRES_URL
# Supabase users: paste the Postgres connection string from Project Settings -> Database
DATABASE_URL=postgresql://USERNAME:PASSWORD@HOST:5432/cms_bridge
POSTGRES_URL=

# Server settings
PORT=3456
HOST=0.0.0.0

# Optional runtime settings
LOG_LEVEL=info
# Supabase and most hosted Postgres providers should use "require"
PGSSLMODE=disable
PG_POOL_SIZE=3
